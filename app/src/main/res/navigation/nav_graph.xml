<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navgraph"
    app:startDestination="@id/splashScreen">

    <activity
        android:id="@+id/mainActivity"
        android:name="com.xstar.schoolswitchcontrolapp.MainActivity"
        android:label="activity_main"
        tools:layout="@layout/activity_main" />

    <fragment
        android:id="@+id/splashScreen"
        android:name="com.xstar.schoolswitchcontrolapp.fragment.SplashScreen"
        android:label="fragment_splash_screen"
        tools:layout="@layout/fragment_splash_screen" >
        <action
            android:id="@+id/action_splashScreen_to_displayControl"
            app:destination="@id/displayControl" />
    </fragment>
    <fragment
        android:id="@+id/displayControl"
        android:name="com.xstar.schoolswitchcontrolapp.fragment.DisplayControl"
        android:label="fragment_display_control"
        tools:layout="@layout/fragment_display_control" />
</navigation>